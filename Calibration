# [Calibration.py]
# Kamerakalibrierung: Berechnet aus Fotos eines
# Schachbrettmusters (ChArUco-Board) die Kameramatrix
# und Verzerrungskoeffizienten und speichert sie ab.
########################################################

#%%
import os
import numpy as np
import cv2
from set_params import (
    ARUCO_DICT,
    CAL_IMAGES_DIR,
    CAMERA_MATRIX_PATH,
    DIST_COEFFS_PATH,
    MARKER_LENGTH,
    PREVIEW_SIZE,
    SQUARE_LENGTH,
    SQUARES_HORIZONTALLY,
    SQUARES_VERTICALLY,
    check_opencv_version,
) # Einladen der definierten Parameter, Pfade und des Versionschecks

# Prüfe beim Start, ob eine ausreichend neue OpenCV-Version installiert ist
check_opencv_version()


# Hilfsfunktion: Bild auf 16:9-Vorschaugröße verkleinern
def to_16_9_preview(image):
    return cv2.resize(image, PREVIEW_SIZE, interpolation=cv2.INTER_AREA)


# Zeigt während der Kalibrierung kurz an, welche Ecken des Boards erkannt wurden
def show_detection_debug_preview(debug_image):
    cv2.imshow('Detection Debug', to_16_9_preview(debug_image))
    cv2.waitKey(150)


# Zeigt die entzerrten Kalibrierbilder kurz als Vorschau an
def show_undistorted_preview(undistorted_image):
    undistorted_preview = cv2.resize(
        undistorted_image, PREVIEW_SIZE, interpolation=cv2.INTER_AREA)
    cv2.imshow('Undistorted Image', undistorted_preview)
    cv2.waitKey(150)


# Berechnet und druckt den Reprojektionsfehler pro Bild (je kleiner, desto besser)
def print_per_image_rms(
    object_points,
    image_points,
    rvecs,
    tvecs,
    camera_matrix,
    dist_coeffs,
    image_labels,
):
    print("\nReprojektionsfehler pro Bild (RMS):")
    for i in range(len(rvecs)):
        projected_points, _ = cv2.projectPoints(
            object_points[i],
            rvecs[i],
            tvecs[i],
            camera_matrix,
            dist_coeffs,
        )

        error = cv2.norm(image_points[i], projected_points, cv2.NORM_L2)
        rms = np.sqrt(error ** 2 / len(projected_points))

        label = image_labels[i] if i < len(image_labels) else f"frame_{i:02d}"
        print(f"{label}: {rms:.6f}")


# Hauptfunktion: Liest Kalibrierbilder ein, erkennt das Board,
# berechnet die Kameraparameter und speichert sie.
def calibrate_and_save_parameters(
    show_detection_previews=True,
    show_undistorted_previews=True,
):
    # Schachbrettmuster (ChArUco-Board) definieren –
    # muss identisch mit dem in BoardGen.py erstellten Board sein
    dictionary = cv2.aruco.getPredefinedDictionary(ARUCO_DICT)
    board = cv2.aruco.CharucoBoard(
        (SQUARES_VERTICALLY, SQUARES_HORIZONTALLY),
        SQUARE_LENGTH, MARKER_LENGTH,
        dictionary)

    # Detektor für ArUco-Marker erstellen
    params = cv2.aruco.DetectorParameters()
    aruco_detector = cv2.aruco.ArucoDetector(dictionary, params)

    # Detektor für ChArUco-Ecken (Schnittpunkte der Schachbrettfelder) erstellen
    charuco_detector = cv2.aruco.CharucoDetector(board)

    # Alle Kalibrierbilder aus dem Ordner laden
    image_files = [
        os.path.join(str(CAL_IMAGES_DIR), f)
        for f in os.listdir(CAL_IMAGES_DIR)
        if f.endswith(".JPG")
    ]
    image_files.sort()

    # Listen zum Sammeln der erkannten Punkte über alle Bilder hinweg
    all_charuco_corners = []
    all_charuco_ids = []
    all_object_points = []  # 3D-Weltpunkte
    all_image_points = []   # 2D-Bildpunkte
    used_image_labels = []

    image_size = None  # Wird beim ersten Bild gesetzt (Breite, Höhe)

    for image_file in image_files:
        image = cv2.imread(image_file)
        debug_draw = image.copy()  # Kopie für die farbige Einzeichnung der Erkennung

        # Bildgröße beim ersten Bild speichern (OpenCV erwartet Breite × Höhe)
        if image_size is None:
            image_size = (image.shape[1], image.shape[0])

        # Schritt 1: ArUco-Marker im Bild suchen
        marker_corners, marker_ids, _ = aruco_detector.detectMarkers(image)

        if marker_ids is not None and len(marker_ids) > 0:
            # Erkannte Marker zur Kontrolle einzeichnen
            cv2.aruco.drawDetectedMarkers(debug_draw, marker_corners, marker_ids)

            # Schritt 2: Aus den erkannten Markern die Schachbrett-Ecken berechnen
            # (Die ersten beiden Rückgabewerte sind immer Ecken und IDs)
            detected = charuco_detector.detectBoard(image)
            charuco_corners, charuco_ids = detected[0], detected[1]
            charuco_retval = 0 if charuco_ids is None else len(charuco_ids)

            if (
                charuco_retval
                and charuco_corners is not None
                and charuco_ids is not None
            ):
                cv2.aruco.drawDetectedCornersCharuco(
                    debug_draw, charuco_corners, charuco_ids, (0, 255, 0)
                )
        else:
            charuco_corners = None
            charuco_ids = None
            charuco_retval = 0

        # Nur Bilder verwenden, in denen mindestens 4 Ecken erkannt wurden
        if charuco_retval and charuco_ids is not None and len(charuco_ids) >= 4:
            # 3D-Weltpunkte den erkannten 2D-Bildpunkten zuordnen
            obj_pts, img_pts = board.matchImagePoints(charuco_corners, charuco_ids)

            if obj_pts is not None and img_pts is not None:
                all_charuco_corners.append(charuco_corners)
                all_charuco_ids.append(charuco_ids)
                all_object_points.append(obj_pts)
                all_image_points.append(img_pts)
                used_image_labels.append(os.path.basename(image_file))

        if show_detection_previews:
            cv2.putText(
                debug_draw,
                os.path.basename(image_file),
                (20, 35),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.9,
                (0, 255, 0),
                2,
                cv2.LINE_AA,
            )
            show_detection_debug_preview(debug_draw)

    # Prüfen, ob überhaupt auswertbare Bilder gefunden wurden
    if len(all_object_points) == 0:
        raise RuntimeError("In keinem Bild wurden ChArUco-Ecken erkannt!")

    # Kamera kalibrieren: Berechnet Kameramatrix und Verzerrungskoeffizienten
    retval, camera_matrix, dist_coeffs, rvecs, tvecs = cv2.calibrateCamera(
        all_object_points,
        all_image_points,
        image_size,
        None,
        None,
    )

    print_per_image_rms(
        all_object_points,
        all_image_points,
        rvecs,
        tvecs,
        camera_matrix,
        dist_coeffs,
        used_image_labels,
    )
    print(f"\nGesamter RMS-Reprojektionsfehler: {retval:.6f}")

    # Kalibrierungsdaten speichern
    np.save(str(CAMERA_MATRIX_PATH), camera_matrix)
    np.save(str(DIST_COEFFS_PATH), dist_coeffs)

    # Entzerrte Vorschauen anzeigen (optional)
    if show_undistorted_previews:
        for image_file in image_files:
            image = cv2.imread(image_file)
            undistorted_image = cv2.undistort(image, camera_matrix, dist_coeffs)
            show_undistorted_preview(undistorted_image)

    cv2.destroyAllWindows()
    return {
        "camera_matrix_path": str(CAMERA_MATRIX_PATH),
        "dist_coeffs_path": str(DIST_COEFFS_PATH),
        "image_count": len(image_files),
        "detected_frame_count": len(all_object_points),
        "rms": float(retval),
    }


# Wird nur ausgeführt, wenn diese Datei direkt gestartet wird (nicht bei Import)
if __name__ == "__main__":
    result = calibrate_and_save_parameters()
    print("RMS:", result["rms"])
    print("Verwendete Kalibrierbilder:", result["image_count"])
    print("Ausgewertete Frames:", result["detected_frame_count"])
    print("Kameramatrix:", np.load(CAMERA_MATRIX_PATH))
    print("Verzerrungskoeffizienten:", np.load(DIST_COEFFS_PATH))


